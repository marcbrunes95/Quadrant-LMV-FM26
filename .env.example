# Variables d'entorn del Quadrant LMV — COPIA aquest fitxer a quadrant-fm/.env.local
# i omple els valors. MAI posis els valors reals aquí ni a git.
# (Detall a README.md → secció "Variables d'Entorn".)

# URL del projecte Supabase (pública)
NEXT_PUBLIC_SUPABASE_URL=

# Clau publishable/anon del navegador (pública, protegida per RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clau secreta service_role — NOMÉS servidor, mai al client ni a git
SUPABASE_SERVICE_ROLE_KEY=

# Contrasenya del panell /admin
ADMIN_KEY=
